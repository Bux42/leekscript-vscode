{
  "name": "leekscript-advanced",
  "displayName": "LeekScript (Advanced)",
  "description": "Language support for LeekScript, the programming language of LeekWars. Provides syntax highlighting, code completion, and integration with LeekWars services.",
  "version": "0.0.6",
  "icon": "images/leekscript-icon.png",
  "publisher": "Bux42",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "leekscript",
        "aliases": [
          "LeekScript",
          "leekscript"
        ],
        "extensions": [
          ".leek",
          ".ls"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./images/leekscript-icon.png",
          "dark": "./images/leekscript-icon.png"
        }
      }
    ],
    "grammars": [
      {
        "language": "leekscript",
        "scopeName": "source.leekscript",
        "path": "./syntaxes/leekscript.tmLanguage.json"
      }
    ],
    "configuration": {
      "title": "LeekScript",
      "properties": {
        "leekscript.leekwarsApiToken": {
          "type": "string",
          "default": "",
          "description": "LeekWars API token for authentication",
          "scope": "resource",
          "markdownDescription": "Your LeekWars API token for authenticating with LeekWars services. This value is stored securely.",
          "format": "password"
        },
        "leekscript.javaApiUrl": {
          "type": "string",
          "default": "http://localhost:8080",
          "scope": "resource",
          "description": "URL for the local Java API server (LeekScript Code Analysis Server)"
        }
      }
    },
    "commands": [
      {
        "command": "leekscript.pullAllAIs",
        "title": "LeekWars: Pull All AIs",
        "category": "LeekScript"
      },
      {
        "command": "leekscript.forceSyncAll",
        "title": "LeekWars: Force Sync All",
        "category": "LeekScript"
      },
      {
        "command": "leekscript.pullAI",
        "title": "LeekWars: Pull AI",
        "category": "LeekScript"
      },
      {
        "command": "leekscript.showStatusMenu",
        "title": "Show Status Menu",
        "category": "LeekScript"
      },
      {
        "command": "leekscript.refreshStatus",
        "title": "Refresh Status",
        "category": "LeekScript"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/js-beautify": "^1.14.3",
    "@types/node": "^18.0.0",
    "@types/vscode": "^1.80.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.40.0",
    "typescript": "^5.1.0"
  },
  "dependencies": {
    "js-beautify": "^1.15.4"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Bux42/leekscript-vscode.git"
  }
}
